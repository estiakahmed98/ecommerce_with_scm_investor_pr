  effectiveTo                  DateTime?
  evaluationWindowDays         Int                          @default(90)
  minTrackedPoCount            Int                          @default(3)
  targetLeadTimeDays           Int
  minimumOnTimeRate            Decimal                      @default(90) @db.Decimal(5, 2)
  minimumFillRate              Decimal                      @default(95) @db.Decimal(5, 2)
  maxOpenLatePoCount           Int                          @default(0)
