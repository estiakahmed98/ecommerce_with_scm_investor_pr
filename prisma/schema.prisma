  updatedAt                    DateTime                     @updatedAt
  breaches                     SupplierSlaBreach[]
  financialRule                SupplierSlaFinancialRule?
  terminationCases             SupplierSlaTerminationCase[]
  createdBy                    User?                        @relation("SupplierSlaPoliciesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  supplier                     Supplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  updatedBy                    User?                        @relation("SupplierSlaPoliciesUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([createdById])
  @@index([updatedById])
}

model SupplierSlaFinancialRule {
  id                              Int               @id @default(autoincrement())
  supplierSlaPolicyId             Int               @unique
  isActive                        Boolean           @default(true)
  holdPaymentsOnThreeWayVariance  Boolean           @default(true)
  holdPaymentsOnOpenSlaAction     Boolean           @default(true)
  allowPaymentHoldOverride        Boolean           @default(true)
  autoCreditRecommendationEnabled Boolean           @default(true)
  autoApplyRecommendedCredit      Boolean           @default(false)
  autoApplyRequireMatchedInvoice  Boolean           @default(true)
  autoApplyBlockOnOpenDispute     Boolean           @default(true)
  warningPenaltyRatePercent       Decimal           @default(0) @db.Decimal(5, 2)
  breachPenaltyRatePercent        Decimal           @default(2) @db.Decimal(5, 2)
  criticalPenaltyRatePercent      Decimal           @default(5) @db.Decimal(5, 2)
  minBreachCountForCredit         Int               @default(1)
  autoApplyMaxAmount              Decimal?          @db.Decimal(12, 2)
  maxCreditCapAmount              Decimal?          @db.Decimal(12, 2)
  note                            String?
  createdById                     String?
  updatedById                     String?
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime          @updatedAt
  createdBy                       User?             @relation("SupplierSlaFinancialRulesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  policy                          SupplierSlaPolicy @relation(fields: [supplierSlaPolicyId], references: [id], onDelete: Cascade)
  updatedBy                       User?             @relation("SupplierSlaFinancialRulesUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([createdById])
  @@index([updatedById])
}

model SupplierSlaBreach {
  id                        Int                          @id @default(autoincrement())
  supplierSlaPolicyId       Int
  supplierId                Int
  evaluationDate            DateTime                     @default(now())
  periodStart               DateTime
  periodEnd                 DateTime
  trackedPoCount            Int                          @default(0)
  completedPoCount          Int                          @default(0)
  openLatePoCount           Int                          @default(0)
  breachCount               Int                          @default(0)
  status                    SupplierSlaEvaluationStatus  @default(OK)
  severity                  SupplierSlaSeverity          @default(LOW)
  observedLeadTimeDays      Decimal?                     @db.Decimal(8, 2)
  onTimeRatePercent         Decimal?                     @db.Decimal(5, 2)
  fillRatePercent           Decimal?                     @db.Decimal(5, 2)
  actionStatus              SupplierSlaActionStatus      @default(NOT_REQUIRED)
  ownerUserId               String?
  dueDate                   DateTime?
  startedAt                 DateTime?
  resolvedAt                DateTime?
  resolvedById              String?
  resolutionNote            String?
  alertTriggeredAt          DateTime?
  alertMessage              String?
  alertAcknowledgedAt       DateTime?
  disputeStatus             SupplierSlaDisputeStatus     @default(NONE)
  disputeReason             String?
  disputeRaisedAt           DateTime?
  disputeRaisedById         String?
  disputeResolutionNote     String?
  disputeResolvedAt         DateTime?
  disputeResolvedById       String?
  terminationCaseId         Int?
  terminationSuggestedAt    DateTime?
  terminationSuggestionNote String?
  issues                    Json?
  evaluatedById             String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  disputeRaisedBy           User?                        @relation("SupplierSlaBreachesDisputeRaised", fields: [disputeRaisedById], references: [id], onDelete: SetNull)
  disputeResolvedBy         User?                        @relation("SupplierSlaBreachesDisputeResolved", fields: [disputeResolvedById], references: [id], onDelete: SetNull)
  owner                     User?                        @relation("SupplierSlaBreachesOwned", fields: [ownerUserId], references: [id], onDelete: SetNull)
  resolvedBy                User?                        @relation("SupplierSlaBreachesResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  evaluatedBy               User?                        @relation("SupplierSlaBreachesEvaluated", fields: [evaluatedById], references: [id], onDelete: SetNull)
  policy                    SupplierSlaPolicy            @relation(fields: [supplierSlaPolicyId], references: [id], onDelete: Cascade)
  supplier                  Supplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  terminationCase           SupplierSlaTerminationCase?  @relation(fields: [terminationCaseId], references: [id], onDelete: SetNull)
  triggeredTerminationCases SupplierSlaTerminationCase[] @relation("SupplierSlaTerminationTriggerBreach")

  @@index([supplierId, evaluationDate])
  @@index([supplierSlaPolicyId, evaluationDate])
  @@index([status, evaluationDate])
  @@index([actionStatus, dueDate])
  @@index([disputeStatus, evaluationDate])
  @@index([ownerUserId, actionStatus])
  @@index([disputeRaisedById])
  @@index([disputeResolvedById])
  @@index([terminationCaseId])
  @@index([resolvedById])
  @@index([evaluatedById])
}

