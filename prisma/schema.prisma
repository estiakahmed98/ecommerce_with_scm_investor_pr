generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                  @id @default(cuid())
  email                         String                  @unique
  name                          String?
  role                          String                  @default("user")
  phone                         String?
  passwordHash                  String?                 @map("password")
  emailVerified                 DateTime?
  image                         String?
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  banned                        Boolean?
  banReason                     String?
  banExpires                    Int?
  note                          String?
  activityLogs                  ActivityLog[]
  cart                          CartItem[]
  assignedChats                 ChatConversation[]      @relation("AssignedChats")
  userChats                     ChatConversation[]      @relation("UserChats")
  chatMessages                  ChatMessage[]
  deliveryProofs                DeliveryProof[]
  inventoryReservations         InventoryReservation[]
  orders                        Order[]
  payrollEntries                PayrollEntry[]
  payrollProfile                PayrollProfile?
  refunds                       Refund[]
  reviews                       Review[]
  serviceBookings               ServiceBooking[]
  assignedShipments             Shipment[]              @relation("AssignedShipments")
  shipmentAssignmentsBy         ShipmentAssignment[]    @relation("ShipmentAssignmentBy")
  shipmentAssignmentsTo         ShipmentAssignment[]    @relation("ShipmentAssignmentTo")
  shipmentCostLogsCreated       ShipmentCostLog[]
  addresses                     UserAddress[]
  assignedUserRoles             UserRole[]              @relation("AssignedUserRoles")
  userRoles                     UserRole[]              @relation("UserRoles")
  assignedWarehouseMemberships  WarehouseMembership[]   @relation("AssignedWarehouseMemberships")
  warehouseMemberships          WarehouseMembership[]   @relation("WarehouseMemberships")
  purchaseOrdersCreated         PurchaseOrder[]         @relation("PurchaseOrdersCreated")
  purchaseOrdersApproved        PurchaseOrder[]         @relation("PurchaseOrdersApproved")
  purchaseOrdersManagerApproved PurchaseOrder[]         @relation("PurchaseOrdersManagerApproved")
  purchaseOrdersCommitteeApproved PurchaseOrder[]       @relation("PurchaseOrdersCommitteeApproved")
  purchaseOrdersFinalApproved   PurchaseOrder[]         @relation("PurchaseOrdersFinalApproved")
  purchaseOrdersRejected        PurchaseOrder[]         @relation("PurchaseOrdersRejected")
  purchaseOrderApprovalEvents   PurchaseOrderApprovalEvent[] @relation("PurchaseOrderApprovalEvents")
  purchaseOrderNotificationsReceived PurchaseOrderNotification[] @relation("PurchaseOrderNotificationsReceived")
  purchaseOrderTermsTemplatesCreated PurchaseOrderTermsTemplate[] @relation("PurchaseOrderTermsTemplatesCreated")
  purchaseOrderTermsTemplatesUpdated PurchaseOrderTermsTemplate[] @relation("PurchaseOrderTermsTemplatesUpdated")
  purchaseOrderLandedCostsCreated PurchaseOrderLandedCost[] @relation("PurchaseOrderLandedCostsCreated")
  purchaseRequisitionsCreated   PurchaseRequisition[]   @relation("PurchaseRequisitionsCreated")
  purchaseRequisitionsApproved  PurchaseRequisition[]   @relation("PurchaseRequisitionsApproved")
  purchaseRequisitionsConverted PurchaseRequisition[]   @relation("PurchaseRequisitionsConverted")
  purchaseRequisitionsBudgetCleared PurchaseRequisition[] @relation("PurchaseRequisitionsBudgetCleared")
  purchaseRequisitionsEndorsed PurchaseRequisition[] @relation("PurchaseRequisitionsEndorsed")
  purchaseRequisitionsAssignedProcurement PurchaseRequisition[] @relation("PurchaseRequisitionsAssignedProcurement")
  purchaseRequisitionAttachmentsUploaded PurchaseRequisitionAttachment[] @relation("PurchaseRequisitionAttachmentsUploaded")
  purchaseRequisitionApprovalEvents PurchaseRequisitionApprovalEvent[] @relation("PurchaseRequisitionApprovalEvents")
  purchaseRequisitionVersionsCreated PurchaseRequisitionVersion[] @relation("PurchaseRequisitionVersionsCreated")
  purchaseRequisitionNotificationsReceived PurchaseRequisitionNotification[] @relation("PurchaseRequisitionNotificationsReceived")
  materialRequestsCreated                   MaterialRequest[]                   @relation("MaterialRequestsCreated")
  materialRequestsSupervisorEndorsed        MaterialRequest[]                   @relation("MaterialRequestsSupervisorEndorsed")
  materialRequestsProjectManagerEndorsed    MaterialRequest[]                   @relation("MaterialRequestsProjectManagerEndorsed")
  materialRequestsAdminApproved             MaterialRequest[]                   @relation("MaterialRequestsAdminApproved")
  materialRequestsRejected                  MaterialRequest[]                   @relation("MaterialRequestsRejected")
  materialRequestAttachmentsUploaded        MaterialRequestAttachment[]         @relation("MaterialRequestAttachmentsUploaded")
  materialRequestApprovalEvents             MaterialRequestApprovalEvent[]      @relation("MaterialRequestApprovalEvents")
  materialReleasesIssued                    MaterialReleaseNote[]               @relation("MaterialReleasesIssued")
  assetRegistersCreated                     AssetRegister[]                     @relation("AssetRegistersCreated")
  inventoryVerificationsCreated            InventoryVerification[]             @relation("InventoryVerificationsCreated")
  inventoryVerificationsApproved           InventoryVerification[]             @relation("InventoryVerificationsApproved")
  inventoryVerificationEvents              InventoryVerificationApprovalEvent[] @relation("InventoryVerificationApprovalEvents")
  inventoryVerificationCommitteeMemberships InventoryVerificationCommitteeMember[] @relation("InventoryVerificationCommitteeMemberships")
  stockAlertsCreated                        ReorderAlert[]                      @relation("ReorderAlertsCreated")
  goodsReceiptsReceived         GoodsReceipt[]          @relation("GoodsReceiptsReceived")
  goodsReceiptsRequesterConfirmed GoodsReceipt[]        @relation("GoodsReceiptsRequesterConfirmed")
  goodsReceiptAttachmentsUploaded GoodsReceiptAttachment[] @relation("GoodsReceiptAttachmentsUploaded")
  goodsReceiptVendorEvaluations  GoodsReceiptVendorEvaluation[] @relation("GoodsReceiptVendorEvaluationsBy")
  supplierReturnsCreated        SupplierReturn[]        @relation("SupplierReturnsCreated")
  supplierReturnsApproved       SupplierReturn[]        @relation("SupplierReturnsApproved")
  supplierReturnsDispatched     SupplierReturn[]        @relation("SupplierReturnsDispatched")
  supplierReturnsClosed         SupplierReturn[]        @relation("SupplierReturnsClosed")
  supplierInvoicesCreated       SupplierInvoice[]       @relation("SupplierInvoicesCreated")
  supplierInvoicesMatched       SupplierInvoice[]       @relation("SupplierInvoicesMatched")
  supplierInvoicePaymentHoldsReleased SupplierInvoice[] @relation("SupplierInvoicePaymentHoldsReleased")
  supplierPaymentsCreated       SupplierPayment[]       @relation("SupplierPaymentsCreated")
  supplierLedgerEntriesCreated  SupplierLedgerEntry[]   @relation("SupplierLedgerEntriesCreated")
  paymentRequestsCreated                 PaymentRequest[]             @relation("PaymentRequestsCreated")
  paymentRequestsManagerApproved         PaymentRequest[]             @relation("PaymentRequestsManagerApproved")
  paymentRequestsFinanceApproved         PaymentRequest[]             @relation("PaymentRequestsFinanceApproved")
  paymentRequestsTreasuryProcessed       PaymentRequest[]             @relation("PaymentRequestsTreasuryProcessed")
  paymentRequestsRejected                PaymentRequest[]             @relation("PaymentRequestsRejected")
  paymentRequestsCancelled               PaymentRequest[]             @relation("PaymentRequestsCancelled")
  paymentRequestApprovalEvents           PaymentRequestApprovalEvent[] @relation("PaymentRequestApprovalEvents")
  paymentRequestNotificationsReceived    PaymentRequestNotification[]  @relation("PaymentRequestNotificationsReceived")
  paymentRequestNotificationsCreated     PaymentRequestNotification[]  @relation("PaymentRequestNotificationsCreatedBy")
  warehouseTransfersCreated     WarehouseTransfer[]     @relation("WarehouseTransfersCreated")
  warehouseTransfersApproved    WarehouseTransfer[]     @relation("WarehouseTransfersApproved")
  warehouseTransfersDispatched  WarehouseTransfer[]     @relation("WarehouseTransfersDispatched")
  warehouseTransfersReceived    WarehouseTransfer[]     @relation("WarehouseTransfersReceived")
  rfqsCreated                   Rfq[]                   @relation("RfqsCreated")
  rfqsApproved                  Rfq[]                   @relation("RfqsApproved")
  rfqAttachmentsUploaded        RfqAttachment[]         @relation("RfqAttachmentsUploaded")
  rfqCategoryTargetsCreated     RfqCategoryTarget[]     @relation("RfqCategoryTargetsCreated")
  rfqNotificationsCreated       RfqNotification[]       @relation("RfqNotificationsCreated")
  rfqSupplierInvitesCreated     RfqSupplierInvite[]     @relation("RfqSupplierInvitesCreated")
  supplierQuotationsSubmitted   SupplierQuotation[]     @relation("SupplierQuotationsSubmitted")
  supplierQuotationAttachmentsUploaded SupplierQuotationAttachment[] @relation("SupplierQuotationAttachmentsUploaded")
  rfqAwardsGranted              RfqAward[]              @relation("RfqAwardsGranted")
  comparativeStatementsCreated  ComparativeStatement[]  @relation("ComparativeStatementsCreated")
  comparativeStatementsUpdated  ComparativeStatement[]  @relation("ComparativeStatementsUpdated")
  comparativeStatementsManagerApproved ComparativeStatement[] @relation("ComparativeStatementsManagerApproved")
  comparativeStatementsCommitteeApproved ComparativeStatement[] @relation("ComparativeStatementsCommitteeApproved")
  comparativeStatementsFinalApproved ComparativeStatement[] @relation("ComparativeStatementsFinalApproved")
  comparativeStatementsRejected ComparativeStatement[]  @relation("ComparativeStatementsRejected")
  comparativeStatementApprovalEvents ComparativeStatementApprovalEvent[] @relation("ComparativeStatementApprovalEvents")
  comparativeStatementNotificationsReceived ComparativeStatementNotification[] @relation("ComparativeStatementNotificationsReceived")
  supplierCategoriesCreated     SupplierCategory[]      @relation("SupplierCategoriesCreated")
  supplierCategorySuppliersCreated SupplierCategorySupplier[] @relation("SupplierCategorySuppliersCreated")
  replenishmentRulesCreated     ReplenishmentRule[]     @relation("ReplenishmentRulesCreated")
  replenishmentRulesUpdated     ReplenishmentRule[]     @relation("ReplenishmentRulesUpdated")
  supplierSlaPoliciesCreated    SupplierSlaPolicy[]     @relation("SupplierSlaPoliciesCreated")
  supplierSlaPoliciesUpdated    SupplierSlaPolicy[]     @relation("SupplierSlaPoliciesUpdated")
  supplierSlaBreachesEvaluated  SupplierSlaBreach[]     @relation("SupplierSlaBreachesEvaluated")
  supplierSlaBreachesOwned      SupplierSlaBreach[]     @relation("SupplierSlaBreachesOwned")
  supplierSlaBreachesResolved   SupplierSlaBreach[]     @relation("SupplierSlaBreachesResolved")
  supplierSlaBreachesDisputeRaised SupplierSlaBreach[]  @relation("SupplierSlaBreachesDisputeRaised")
  supplierSlaBreachesDisputeResolved SupplierSlaBreach[] @relation("SupplierSlaBreachesDisputeResolved")
  supplierSlaFinancialRulesCreated SupplierSlaFinancialRule[] @relation("SupplierSlaFinancialRulesCreated")
  supplierSlaFinancialRulesUpdated SupplierSlaFinancialRule[] @relation("SupplierSlaFinancialRulesUpdated")
  supplierSlaTerminationCasesCreated SupplierSlaTerminationCase[] @relation("SupplierSlaTerminationCasesCreated")
  supplierSlaTerminationCasesOwned SupplierSlaTerminationCase[] @relation("SupplierSlaTerminationCasesOwned")
  supplierSlaTerminationCasesResolved SupplierSlaTerminationCase[] @relation("SupplierSlaTerminationCasesResolved")
  verifiedSupplierDocuments      SupplierDocument[]       @relation("SupplierDocumentsVerifiedBy")
  supplierProfileUpdateRequestsSubmitted SupplierProfileUpdateRequest[] @relation("SupplierProfileUpdateRequestsSubmitted")
  supplierProfileUpdateRequestsReviewed SupplierProfileUpdateRequest[] @relation("SupplierProfileUpdateRequestsReviewed")
  supplierFeedbackCreated        SupplierFeedback[]       @relation("SupplierFeedbackCreated")
  supplierPortalNotificationsCreated SupplierPortalNotification[] @relation("SupplierPortalNotificationsCreatedBy")
  supplierPortalNotifications    SupplierPortalNotification[] @relation("SupplierPortalNotificationsUser")
  wishlist                      Wishlist[]
  analyticsEvents               AnalyticsEvent[]
  deliveryManProfile            DeliveryManProfile?
  verifiedDeliveryMen           DeliveryManProfile[]    @relation("VerifiedDeliveryMen")
  assignedDeliveryMen           DeliveryManProfile[]    @relation("AssignedDeliveryMen")
  verifiedDeliveryManDocuments  DeliveryManDocument[]   @relation("VerifiedDeliveryManDocuments")
  createdDeliveryAssignments    DeliveryAssignment[]    @relation("CreatedDeliveryAssignments")
  deliveryAssignmentLogsCreated DeliveryAssignmentLog[] @relation("DeliveryAssignmentLogsCreated")
  pickupProofsCreated           WarehousePickupProof[]  @relation("WarehousePickupProofsCreated")
  supplierPortalAccess          SupplierPortalAccess?   @relation("SupplierPortalAccessUser")
  createdSupplierPortalAccesses SupplierPortalAccess[]  @relation("SupplierPortalAccessCreatedBy")
  investorPortalAccess          InvestorPortalAccess?   @relation("InvestorPortalAccessUser")
  createdInvestorPortalAccesses InvestorPortalAccess[]  @relation("InvestorPortalAccessCreatedBy")
  investorsCreated              Investor[]              @relation("InvestorsCreated")
  investorCapitalTransactionsCreated InvestorCapitalTransaction[] @relation("InvestorCapitalTransactionsCreated")
  investorProductAllocationsCreated InvestorProductAllocation[] @relation("InvestorProductAllocationsCreated")
  investorProfitRunsCreated     InvestorProfitRun[]     @relation("InvestorProfitRunsCreated")
  investorProfitRunsApproved    InvestorProfitRun[]     @relation("InvestorProfitRunsApproved")
  investorProfitRunsPosted      InvestorProfitRun[]     @relation("InvestorProfitRunsPosted")
  investorProfitPayoutsCreated  InvestorProfitPayout[]  @relation("InvestorProfitPayoutsCreated")
  investorProfitPayoutsApproved InvestorProfitPayout[]  @relation("InvestorProfitPayoutsApproved")
  investorProfitPayoutsRejected InvestorProfitPayout[]  @relation("InvestorProfitPayoutsRejected")
  investorProfitPayoutsPaid     InvestorProfitPayout[]  @relation("InvestorProfitPayoutsPaid")
  investorProfitPayoutsReleased InvestorProfitPayout[]  @relation("InvestorProfitPayoutsReleased")
  investorProfitPayoutsVoided   InvestorProfitPayout[]  @relation("InvestorProfitPayoutsVoided")
  investorDocumentsUploaded     InvestorDocument[]      @relation("InvestorDocumentsUploadedBy")
  investorDocumentsReviewed     InvestorDocument[]      @relation("InvestorDocumentsReviewedBy")
  investorMasterChangeRequestsRequested InvestorMasterChangeRequest[] @relation("InvestorMasterChangeRequestsRequestedBy")
  investorMasterChangeRequestsReviewed  InvestorMasterChangeRequest[] @relation("InvestorMasterChangeRequestsReviewedBy")
  investorsBeneficiaryVerified          Investor[]        @relation("InvestorBeneficiaryVerifiedBy")
  investorProfileUpdateRequestsSubmitted InvestorProfileUpdateRequest[] @relation("InvestorProfileUpdateRequestsSubmittedBy")
  investorProfileUpdateRequestsReviewed  InvestorProfileUpdateRequest[] @relation("InvestorProfileUpdateRequestsReviewedBy")
  investorWithdrawalRequestsSubmitted    InvestorWithdrawalRequest[]     @relation("InvestorWithdrawalRequestsSubmittedBy")
  investorWithdrawalRequestsReviewed     InvestorWithdrawalRequest[]     @relation("InvestorWithdrawalRequestsReviewedBy")
  investorWithdrawalRequestsSettled      InvestorWithdrawalRequest[]     @relation("InvestorWithdrawalRequestsSettledBy")
  investorPortalNotificationsCreated     InvestorPortalNotification[]   @relation("InvestorPortalNotificationsCreatedBy")
  investorInternalNotifications          InvestorInternalNotification[] @relation("InvestorInternalNotificationsUser")
  investorInternalNotificationsCreated   InvestorInternalNotification[] @relation("InvestorInternalNotificationsCreatedBy")
  investorStatementSchedulesCreated      InvestorStatementSchedule[]     @relation("InvestorStatementSchedulesCreatedBy")
  investorStatementSchedulesUpdated      InvestorStatementSchedule[]     @relation("InvestorStatementSchedulesUpdatedBy")
}

model UserAddress {
  id        Int      @id @default(autoincrement())
  userId    String
  label     String
  country   String
  district  String
  area      String
  details   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  label           String
  description     String?
  isSystem        Boolean          @default(false)
  isImmutable     Boolean          @default(false)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([deletedAt])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId       String
  roleId       String
  assignedById String?
  createdAt    DateTime        @default(now())
  id           String          @id @default(cuid())
  scopeType    AccessScopeType @default(GLOBAL)
  updatedAt    DateTime        @updatedAt
  warehouseId  Int?
  assignedBy   User?           @relation("AssignedUserRoles", fields: [assignedById], references: [id])
  role         Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user         User            @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, warehouseId])
  @@index([roleId])
  @@index([warehouseId])
  @@index([assignedById])
}

model Writer {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   Boolean   @default(false)
  products  Product[]
}

model Publisher {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   Boolean   @default(false)
  products  Product[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  image     String?
  parentId  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deleted   Boolean    @default(false)
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  products  Product[]

  @@index([parentId])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   Boolean   @default(false)
  products  Product[]
}

model Product {
  id                      Int                               @id @default(autoincrement())
  name                    String
  slug                    String                            @unique
  type                    ProductType                       @default(PHYSICAL)
  sku                     String?                           @unique
  categoryId              Int
  brandId                 Int?
  writerId                Int?
  publisherId             Int?
  description             String
  shortDesc               String?
  basePrice               Decimal                           @db.Decimal(10, 2)
  originalPrice           Decimal?                          @db.Decimal(10, 2)
  currency                String                            @default("USD") @db.VarChar(3)
  weight                  Float?
  dimensions              Json?
  VatClassId              Int?
  digitalAssetId          Int?
  serviceDurationMinutes  Int?
  serviceLocation         String?
  serviceOnlineLink       String?
  available               Boolean                           @default(true)
  featured                Boolean                           @default(false)
  image                   String?
  gallery                 String[]
  videoUrl                String?
  soldCount               Int                               @default(0)
  ratingAvg               Float                             @default(0)
  ratingCount             Int                               @default(0)
  deleted                 Boolean                           @default(false)
  createdAt               DateTime                          @default(now())
  updatedAt               DateTime                          @updatedAt
  lowStockThreshold       Int                               @default(10)
  inventoryItemClass      InventoryItemClass                @default(CONSUMABLE)
  requiresAssetTag        Boolean                           @default(false)
  bundleStockLimit        Int?
  cartItems               CartItem[]
  dailySnapshots          InventoryDailySnapshot[]
  inventoryLogs           InventoryLog[]
  warehouseDailySnapshots InventoryWarehouseDailySnapshot[]
  orderItems              OrderItem[]
  VatClass                VatClass?                         @relation(fields: [VatClassId], references: [id])
  brand                   Brand?                            @relation(fields: [brandId], references: [id])
  category                Category                          @relation(fields: [categoryId], references: [id])
  digitalAsset            DigitalAsset?                     @relation("ProductDigitalAsset", fields: [digitalAssetId], references: [id])
  publisher               Publisher?                        @relation(fields: [publisherId], references: [id])
  writer                  Writer?                           @relation(fields: [writerId], references: [id])
  attributes              ProductAttribute[]
  codes                   ProductCode[]
  variants                ProductVariant[]
  variantOptions          ProductVariantOption[]
  reviews                 Review[]
  serviceSlots            ServiceSlot[]
  wishlist                Wishlist[]
  bundleItems             ProductBundleItem[]               @relation("BundleProducts")
  includedInBundles       ProductBundleItem[]               @relation("IncludedProducts")
}

model ProductBundleItem {
  id        Int      @id @default(autoincrement())
  bundleId  Int
  productId Int
  quantity  Int      @default(1)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bundle  Product @relation("BundleProducts", fields: [bundleId], references: [id], onDelete: Cascade)
  product Product @relation("IncludedProducts", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
}

model ProductVariant {
  id                           Int                               @id @default(autoincrement())
  productId                    Int
  sku                          String
  price                        Decimal                           @db.Decimal(10, 2)
  currency                     String                            @default("USD") @db.VarChar(3)
  stock                        Int                               @default(0)
  digitalAssetId               Int?
  options                      Json
  colorImage                   String?
  createdAt                    DateTime                          @default(now())
  updatedAt                    DateTime                          @updatedAt
  isDefault                    Boolean                           @default(false)
  active                       Boolean                           @default(true)
  lowStockThreshold            Int                               @default(10)
  costPrice                    Decimal?                          @db.Decimal(10, 2)
  cartItems                    CartItem[]
  dailySnapshots               InventoryDailySnapshot[]
  inventoryLogs                InventoryLog[]
  warehouseDailySnapshots      InventoryWarehouseDailySnapshot[]
  orderItems                   OrderItem[]
  codes                        ProductCode[]
  digitalAsset                 DigitalAsset?                     @relation("VariantDigitalAsset", fields: [digitalAssetId], references: [id])
  product                      Product                           @relation(fields: [productId], references: [id])
  purchaseOrderItems           PurchaseOrderItem[]
  goodsReceiptItems            GoodsReceiptItem[]
  purchaseRequisitionItems     PurchaseRequisitionItem[]
  supplierInvoiceItems         SupplierInvoiceItem[]
  supplierReturnItems          SupplierReturnItem[]
  rfqItems                     RfqItem[]
  supplierQuotationItems       SupplierQuotationItem[]
  replenishmentRules           ReplenishmentRule[]
  warehouseTransferItems       WarehouseTransferItem[]
  stockLevels                  StockLevel[]
  materialRequestItems         MaterialRequestItem[]
  materialReleaseNoteItems     MaterialReleaseNoteItem[]
  assetRegisters               AssetRegister[]
  stockBinLevels               StockBinLevel[]
  inventoryVerificationLines   InventoryVerificationLine[]
  reorderAlerts                ReorderAlert[]
  investorAllocations          InvestorProductAllocation[]
  investorCapitalTransactions  InvestorCapitalTransaction[]
  investorProfitRunVariants    InvestorProfitRunVariant[]
  investorProfitRunAllocations InvestorProfitRunAllocation[]
}

model ProductVariantOption {
  id        Int                         @id @default(autoincrement())
  productId Int
  name      String
  position  Int                         @default(0)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
  product   Product                     @relation(fields: [productId], references: [id])
  values    ProductVariantOptionValue[]

  @@unique([productId, name])
  @@index([productId, position])
}

model ProductVariantOptionValue {
  id        Int                  @id @default(autoincrement())
  optionId  Int
  value     String
  position  Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  option    ProductVariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, value])
  @@index([optionId, position])
}

model ProductCode {
  id        Int                  @id @default(autoincrement())
  productId Int?
  variantId Int?
  kind      ProductCodeKind
  symbology ProductCodeSymbology
  value     String
  token     String?              @unique
  imageUrl  String?
  isPrimary Boolean              @default(true)
  status    String               @default("ACTIVE")
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  product   Product?             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([symbology, value])
  @@index([productId])
  @@index([variantId])
  @@index([kind, status])
}

model DigitalAsset {
  id              Int               @id @default(autoincrement())
  title           String
  fileUrl         String
  storageProvider String?
  fileSize        Int?
  checksum        String?
  mimeType        String?
  maxDownloads    Int?
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deliveries      DigitalDelivery[]
  products        Product[]         @relation("ProductDigitalAsset")
  variants        ProductVariant[]  @relation("VariantDigitalAsset")
}

model DigitalDelivery {
  id             Int           @id @default(autoincrement())
  orderItemId    Int
  digitalAssetId Int
  downloadLimit  Int?
  downloadCount  Int           @default(0)
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  asset          DigitalAsset  @relation(fields: [digitalAssetId], references: [id])
  orderItem      OrderItem     @relation(fields: [orderItemId], references: [id])
  downloads      DownloadLog[]

  @@unique([orderItemId, digitalAssetId])
}

model DownloadLog {
  id                Int             @id @default(autoincrement())
  digitalDeliveryId Int
  ipAddress         String?
  userAgent         String?
  downloadedAt      DateTime        @default(now())
  delivery          DigitalDelivery @relation(fields: [digitalDeliveryId], references: [id])
}

model Attribute {
  id                Int                @id @default(autoincrement())
  name              String
  values            AttributeValue[]
  productAttributes ProductAttribute[]
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  value       String
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
}

model ProductAttribute {
  id          Int       @id @default(autoincrement())
  productId   Int
  attributeId Int
  value       String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
}

model VatClass {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  rates       VatRate[]
}

model VatRate {
  id          Int       @id @default(autoincrement())
  VatClassId  Int
  countryCode String    @db.VarChar(2)
  regionCode  String?   @db.VarChar(10)
  rate        Decimal   @db.Decimal(6, 4)
  inclusive   Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  VatClass    VatClass  @relation(fields: [VatClassId], references: [id])

  @@index([countryCode, regionCode])
}

model Order {
  id                    Int                    @id @default(autoincrement())
  userId                String?
  name                  String
  email                 String?
  phone_number          String
  alt_phone_number      String?
  country               String
  district              String
  area                  String
  address_details       String
  image                 String?
  payment_method        String
  order_date            DateTime               @default(now())
  total                 Decimal                @db.Decimal(10, 2)
  shipping_cost         Decimal                @db.Decimal(10, 2)
  grand_total           Decimal                @db.Decimal(10, 2)
  currency              String                 @default("BDT") @db.VarChar(3)
  Vat_total             Decimal?               @db.Decimal(10, 2)
  discount_total        Decimal?               @db.Decimal(10, 2)
  status                OrderStatus            @default(PENDING)
  paymentStatus         PaymentStatus          @default(UNPAID)
  transactionId         String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  couponId              String?
  taxSnapshot           Json?
  deliveryProofs        DeliveryProof[]
  inventoryReservations InventoryReservation[]
  coupon                Coupon?                @relation(fields: [couponId], references: [id])
  user                  User?                  @relation(fields: [userId], references: [id])
  orderItems            OrderItem[]
  payments              Payment[]
  refunds               Refund[]
  shipments             Shipment?
  deliveryAssignments   DeliveryAssignment[]
}

model Payment {
  id                 Int          @id @default(autoincrement())
  orderId            Int?
  amount             Decimal?     @db.Decimal(10, 2)
  currency           String       @default("BDT") @db.VarChar(3)
  provider           String?
  status             PaymentState @default(INITIATED)
  externalId         String?      @unique
  paymentGatewayData Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  order              Order?       @relation(fields: [orderId], references: [id])
  refunds            Refund[]
}

model OrderItem {
  id                Int               @id @default(autoincrement())
  orderId           Int
  productId         Int
  variantId         Int?
  quantity          Int               @default(1)
  price             Decimal           @db.Decimal(10, 2)
  currency          String            @default("BDT") @db.VarChar(3)
  VatAmount         Decimal?          @db.Decimal(10, 2)
  discountAmount    Decimal?          @db.Decimal(10, 2)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  costPriceSnapshot Decimal?          @db.Decimal(10, 2)
  digitalDeliveries DigitalDelivery[]
  order             Order             @relation(fields: [orderId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])
  variant           ProductVariant?   @relation(fields: [variantId], references: [id])
  refunds           Refund[]
  serviceBooking    ServiceBooking?   @relation("OrderItemServiceBooking")
  shipmentItems     ShipmentItem[]
}

model ServiceSlot {
  id          Int              @id @default(autoincrement())
  productId   Int
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int              @default(1)
  bookedCount Int              @default(0)
  timezone    String?
  location    String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    ServiceBooking[]
  product     Product          @relation(fields: [productId], references: [id])
}

model ServiceBooking {
  id          Int           @id @default(autoincrement())
  slotId      Int
  orderItemId Int?          @unique
  userId      String?
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orderItem   OrderItem?    @relation("OrderItemServiceBooking", fields: [orderItemId], references: [id])
  slot        ServiceSlot   @relation(fields: [slotId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  productId Int
  feature   Boolean? @default(false)
  userId    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model CartItem {
  id        Int             @id @default(autoincrement())
  userId    String
  productId Int
  quantity  Int             @default(1)
  variantId Int?
  product   Product         @relation(fields: [productId], references: [id])
  user      User            @relation(fields: [userId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([variantId])
}

model Wishlist {
  id        Int     @id @default(autoincrement())
  userId    String
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Blog {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  summary   String
  content   String
  date      DateTime
  author    String
  image     String
  ads       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shipment {
  id                              Int                  @id @default(autoincrement())
  orderId                         Int                  @unique
  warehouseId                     Int?
  courier                         String
  courierId                       Int?
  trackingNumber                  String?
  externalId                      String?
  trackingUrl                     String?
  status                          ShipmentStatus       @default(PENDING)
  courierStatus                   String?
  lastSyncedAt                    DateTime?
  shippedAt                       DateTime?
  expectedDate                    DateTime?
  deliveredAt                     DateTime?
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime             @updatedAt
  deliveryConfirmationPin         String?
  deliveryConfirmationRequestedAt DateTime?
  deliveryConfirmationToken       String?              @unique
  actualCost                      Decimal?             @db.Decimal(10, 2)
  assignedAt                      DateTime?
  assignedToUserId                String?
  dispatchNote                    String?
  estimatedCost                   Decimal?             @db.Decimal(10, 2)
  fuelCost                        Decimal?             @db.Decimal(10, 2)
  handlingCost                    Decimal?             @db.Decimal(10, 2)
  outForDeliveryAt                DateTime?
  packagingCost                   Decimal?             @db.Decimal(10, 2)
  pickedAt                        DateTime?
  priority                        Int                  @default(0)
  shippingRateId                  Int?
  thirdPartyCost                  Decimal?             @db.Decimal(10, 2)
  deliveryProof                   DeliveryProof?
  assignedTo                      User?                @relation("AssignedShipments", fields: [assignedToUserId], references: [id])
  courierRef                      Courier?             @relation("ShipmentToCourier", fields: [courierId], references: [id])
  order                           Order                @relation(fields: [orderId], references: [id])
  shippingRate                    ShippingRate?        @relation(fields: [shippingRateId], references: [id])
  warehouse                       Warehouse?           @relation(fields: [warehouseId], references: [id])
  assignments                     ShipmentAssignment[]
  costLogs                        ShipmentCostLog[]
  deliveryAssignments             DeliveryAssignment[]
  items                           ShipmentItem[]
  statusLogs                      ShipmentStatusLog[]

  @@index([courierId])
  @@index([shippingRateId])
  @@index([assignedToUserId])
  @@index([deliveryConfirmationRequestedAt])
}

model DeliveryProof {
  id                Int      @id @default(autoincrement())
  orderId           Int
  shipmentId        Int      @unique
  userId            String?
  tickReceived      Boolean
  tickCorrectItems  Boolean
  tickGoodCondition Boolean
  photoUrl          String?
  note              String?
  confirmedAt       DateTime @default(now())
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id])
  shipment          Shipment @relation(fields: [shipmentId], references: [id])
  user              User?    @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([confirmedAt])
}

model Courier {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  type          CourierType
  baseUrl       String
  apiKey        String?
  secretKey     String?
  clientId      String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  shipments     Shipment[]     @relation("ShipmentToCourier")
  shippingRates ShippingRate[]
}

model Warehouse {
  id                               Int                               @id @default(autoincrement())
  name                             String
  code                             String                            @unique
  address                          Json?
  isDefault                        Boolean                           @default(false)
  createdAt                        DateTime                          @default(now())
  updatedAt                        DateTime                          @updatedAt
  area                             String?
  country                          String?                           @default("BD")
  coverageRadiusKm                 Float?
  district                         String?
  division                         String?
  geoFence                         Json?
  isMapEnabled                     Boolean                           @default(true)
  latitude                         Float?
  locationNote                     String?
  longitude                        Float?
  mapLabel                         String?
  postCode                         String?
  inventoryDailySnapshots          InventoryDailySnapshot[]
  inventoryLogs                    InventoryLog[]
  inventoryWarehouseDailySnapshots InventoryWarehouseDailySnapshot[]
  payrollEntries                   PayrollEntry[]
  payrollProfiles                  PayrollProfile[]
  shipments                        Shipment[]
  shipmentAssignments              ShipmentAssignment[]
  shippingRates                    ShippingRate[]
  stockLevels                      StockLevel[]
  userRoles                        UserRole[]
  memberships                      WarehouseMembership[]
  purchaseOrders                   PurchaseOrder[]
  purchaseRequisitions             PurchaseRequisition[]
  materialRequests                 MaterialRequest[]
  materialReleases                 MaterialReleaseNote[]
  assetRegisters                   AssetRegister[]
  zones                            WarehouseZone[]
  aisles                           WarehouseAisle[]
  bins                             WarehouseBin[]
  stockBinLevels                   StockBinLevel[]
  inventoryVerifications           InventoryVerification[]
  reorderAlerts                    ReorderAlert[]
  rfqs                             Rfq[]
  comparativeStatements            ComparativeStatement[]
  goodsReceipts                    GoodsReceipt[]
  paymentRequests                  PaymentRequest[]
  supplierReturns                  SupplierReturn[]
  replenishmentRules               ReplenishmentRule[]
  transfersFrom                    WarehouseTransfer[]               @relation("WarehouseTransferSource")
  transfersTo                      WarehouseTransfer[]               @relation("WarehouseTransferDestination")
  deliveryMen                      DeliveryManProfile[]
  deliveryAssignments              DeliveryAssignment[]

  @@index([country, division, district, area])
  @@index([latitude, longitude])
}

model WarehouseMembership {
  id           String    @id @default(cuid())
  userId       String
  warehouseId  Int
  isPrimary    Boolean   @default(false)
  status       String    @default("ACTIVE")
  assignedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedBy   User?     @relation("AssignedWarehouseMemberships", fields: [assignedById], references: [id])
  user         User      @relation("WarehouseMemberships", fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, warehouseId])
  @@index([warehouseId])
  @@index([assignedById])
}

model ShippingRate {
  id            Int        @id @default(autoincrement())
  country       String     @default("BD")
  area          String
  baseCost      Decimal    @db.Decimal(10, 2)
  weightSlabs   Json?
  freeMinOrder  Decimal?   @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  priority      Int        @default(1000)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  district      String?
  courierId     Int?
  deliveryType  String?
  estimatedDays Int?
  warehouseId   Int?
  shipments     Shipment[]
  courier       Courier?   @relation(fields: [courierId], references: [id])
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([country, area])
  @@index([isActive, priority])
  @@index([warehouseId])
  @@index([courierId])
}

model StockLevel {
  id               Int                    @id @default(autoincrement())
  warehouseId      Int
  productVariantId Int
  quantity         Int                    @default(0)
  reserved         Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  reservations     InventoryReservation[]
  variant          ProductVariant         @relation(fields: [productVariantId], references: [id])
  warehouse        Warehouse              @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productVariantId])
}

model InventoryReservation {
  id           Int        @id @default(autoincrement())
  stockLevelId Int
  orderId      Int?
  userId       String?
  quantity     Int
  reason       String?
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  order        Order?     @relation(fields: [orderId], references: [id])
  stockLevel   StockLevel @relation(fields: [stockLevelId], references: [id])
  user         User?      @relation(fields: [userId], references: [id])
}

model InventoryDailySnapshot {
  id                Int            @id @default(autoincrement())
  snapshotDate      DateTime       @db.Date
  productId         Int
  variantId         Int
  stock             Int            @default(0)
  lowStockThreshold Int            @default(10)
  status            String         @db.VarChar(20)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  warehouseId       Int?
  product           Product        @relation(fields: [productId], references: [id])
  variant           ProductVariant @relation(fields: [variantId], references: [id])
  warehouse         Warehouse?     @relation(fields: [warehouseId], references: [id])

  @@unique([snapshotDate, variantId])
  @@index([snapshotDate])
}

model InventoryWarehouseDailySnapshot {
  id           Int            @id @default(autoincrement())
  snapshotDate DateTime       @db.Date
  productId    Int
  variantId    Int
  warehouseId  Int
  quantity     Int            @default(0)
  reserved     Int            @default(0)
  available    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  product      Product        @relation(fields: [productId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([snapshotDate, variantId, warehouseId])
  @@index([snapshotDate, warehouseId])
}

model ShipmentItem {
  id          Int       @id @default(autoincrement())
  shipmentId  Int
  orderItemId Int
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  shipment    Shipment  @relation(fields: [shipmentId], references: [id])
}

model ShipmentStatusLog {
  id         Int             @id @default(autoincrement())
  shipmentId Int
  fromStatus ShipmentStatus?
  toStatus   ShipmentStatus
  source     String          @default("SYSTEM")
  note       String?
  createdAt  DateTime        @default(now())
  shipment   Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([toStatus, createdAt])
}

model ShipmentCostLog {
  id          Int      @id @default(autoincrement())
  shipmentId  Int
  costType    String
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  createdBy   User?    @relation(fields: [createdById], references: [id])
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([createdById])
}

model ShipmentAssignment {
  id           Int        @id @default(autoincrement())
  shipmentId   Int
  assignedToId String
  assignedById String?
  warehouseId  Int?
  role         String?
  note         String?
  assignedAt   DateTime   @default(now())
  completedAt  DateTime?
  assignedBy   User?      @relation("ShipmentAssignmentBy", fields: [assignedById], references: [id])
  assignedTo   User       @relation("ShipmentAssignmentTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  shipment     Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([shipmentId])
  @@index([assignedToId])
  @@index([warehouseId])
}

model PayrollProfile {
  id              Int            @id @default(autoincrement())
  userId          String         @unique
  warehouseId     Int?
  employeeCode    String?        @unique
  paymentType     String         @default("MONTHLY")
  baseSalary      Decimal        @db.Decimal(10, 2)
  bankName        String?
  bankAccountNo   String?
  accountHolder   String?
  mobileBankingNo String?
  paymentMethod   String?
  joiningDate     DateTime?
  isActive        Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  entries         PayrollEntry[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
}

model PayrollPeriod {
  id        Int            @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String         @default("OPEN")
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  entries   PayrollEntry[]

  @@unique([startDate, endDate])
}

model PayrollEntry {
  id               Int                 @id @default(autoincrement())
  payrollPeriodId  Int
  payrollProfileId Int
  userId           String
  warehouseId      Int?
  basicAmount      Decimal             @db.Decimal(10, 2)
  overtimeAmount   Decimal             @default(0) @db.Decimal(10, 2)
  bonusAmount      Decimal             @default(0) @db.Decimal(10, 2)
  deductionAmount  Decimal             @default(0) @db.Decimal(10, 2)
  netAmount        Decimal             @db.Decimal(10, 2)
  paymentStatus    String              @default("PENDING")
  paidAt           DateTime?
  note             String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  adjustments      PayrollAdjustment[]
  payrollPeriod    PayrollPeriod       @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  payrollProfile   PayrollProfile      @relation(fields: [payrollProfileId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?          @relation(fields: [warehouseId], references: [id])

  @@unique([payrollPeriodId, payrollProfileId])
  @@index([payrollPeriodId])
  @@index([userId])
  @@index([warehouseId])
}

model PayrollAdjustment {
  id             Int          @id @default(autoincrement())
  payrollEntryId Int
  type           String
  amount         Decimal      @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime     @default(now())
  payrollEntry   PayrollEntry @relation(fields: [payrollEntryId], references: [id], onDelete: Cascade)

  @@index([payrollEntryId])
}

model Refund {
  id          Int          @id @default(autoincrement())
  orderId     Int
  userId      String?
  paymentId   Int?
  orderItemId Int?
  reason      String
  status      RefundStatus @default(REQUESTED)
  amount      Decimal      @db.Decimal(10, 2)
  quantity    Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  order       Order        @relation(fields: [orderId], references: [id])
  orderItem   OrderItem?   @relation(fields: [orderItemId], references: [id])
  payment     Payment?     @relation(fields: [paymentId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([userId])
}

model InventoryLog {
  id          Int             @id @default(autoincrement())
  productId   Int
  variantId   Int?
  warehouseId Int?
  change      Int
  reason      String
  createdAt   DateTime        @default(now())
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  warehouse   Warehouse?      @relation(fields: [warehouseId], references: [id])
}

model Supplier {
  id                        Int                            @id @default(autoincrement())
  code                      String                         @unique
  name                      String
  companyType               SupplierCompanyType            @default(PROPRIETOR)
  contactName               String?
  email                     String?
  phone                     String?
  address                   String?
  city                      String?
  country                   String?                        @default("BD")
  leadTimeDays              Int?
  paymentTermsDays          Int?
  currency                  String                         @default("BDT") @db.VarChar(3)
  taxNumber                 String?
  notes                     String?
  isActive                  Boolean                        @default(true)
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  documents                 SupplierDocument[]
  purchaseOrders            PurchaseOrder[]
  supplierReturns           SupplierReturn[]
  invoices                  SupplierInvoice[]
  payments                  SupplierPayment[]
  paymentRequests           PaymentRequest[]
  ledgerEntries             SupplierLedgerEntry[]
  rfqInvites                RfqSupplierInvite[]
  quotations                SupplierQuotation[]
  comparativeStatementLines ComparativeStatementLine[]
  rfqAwards                 RfqAward[]
  categories                SupplierCategorySupplier[]
  rfqNotifications          RfqNotification[]
  slaPolicies               SupplierSlaPolicy[]
  slaBreaches               SupplierSlaBreach[]
  slaTerminationCases       SupplierSlaTerminationCase[]
  portalAccesses            SupplierPortalAccess[]
  profileUpdateRequests     SupplierProfileUpdateRequest[]
  feedbacks                 SupplierFeedback[]
  portalNotifications       SupplierPortalNotification[]

  @@index([companyType])
  @@index([name])
  @@index([isActive])
}

model SupplierDocument {
  id                 Int                                @id @default(autoincrement())
  supplierId         Int
  type               SupplierDocumentType
  documentNumber     String?
  fileUrl            String
  fileName           String?
  mimeType           String?
  fileSize           Int?
  issuedAt           DateTime?
  expiresAt          DateTime?
  verificationStatus SupplierDocumentVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedById       String?
  verificationNote   String?
  lastReminderAt     DateTime?
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt
  supplier           Supplier                           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  verifiedBy         User?                              @relation("SupplierDocumentsVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@unique([supplierId, type])
  @@index([supplierId])
  @@index([type])
  @@index([expiresAt])
  @@index([verificationStatus])
  @@index([verifiedById])
}

model PurchaseRequisition {
  id                           Int                                @id @default(autoincrement())
  requisitionNumber            String                             @unique
  warehouseId                  Int
  status                       PurchaseRequisitionStatus          @default(DRAFT)
  title                        String?
  purpose                      String?
  budgetCode                   String?
  boqReference                 String?
  specification                String?
  planningNote                 String?
  estimatedAmount              Decimal?                           @db.Decimal(14, 2)
  endorsementRequiredCount     Int                                @default(1)
  requestedAt                  DateTime                           @default(now())
  neededBy                     DateTime?
  submittedAt                  DateTime?
  budgetClearedAt              DateTime?
  endorsedAt                   DateTime?
  approvedAt                   DateTime?
  rejectedAt                   DateTime?
  convertedAt                  DateTime?
  routedToProcurementAt        DateTime?
  createdById                  String?
  budgetClearedById            String?
  endorsedById                 String?
  approvedById                 String?
  convertedById                String?
  assignedProcurementOfficerId String?
  note                         String?
  createdAt                    DateTime                           @default(now())
  updatedAt                    DateTime                           @updatedAt
  approvedBy                   User?                              @relation("PurchaseRequisitionsApproved", fields: [approvedById], references: [id], onDelete: SetNull)
  budgetClearedBy              User?                              @relation("PurchaseRequisitionsBudgetCleared", fields: [budgetClearedById], references: [id], onDelete: SetNull)
  endorsedBy                   User?                              @relation("PurchaseRequisitionsEndorsed", fields: [endorsedById], references: [id], onDelete: SetNull)
  assignedProcurementOfficer   User?                              @relation("PurchaseRequisitionsAssignedProcurement", fields: [assignedProcurementOfficerId], references: [id], onDelete: SetNull)
  convertedBy                  User?                              @relation("PurchaseRequisitionsConverted", fields: [convertedById], references: [id], onDelete: SetNull)
  createdBy                    User?                              @relation("PurchaseRequisitionsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  items                        PurchaseRequisitionItem[]
  attachments                  PurchaseRequisitionAttachment[]
  approvalEvents               PurchaseRequisitionApprovalEvent[]
  versions                     PurchaseRequisitionVersion[]
  notifications                PurchaseRequisitionNotification[]
  rfqs                         Rfq[]
  purchaseOrders               PurchaseOrder[]
  warehouse                    Warehouse                          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([warehouseId, status])
  @@index([createdById])
